      "parameters": {
        "method": "POST",
        "url": "https://www.zohoapis.in/crm/v2/Leads",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
