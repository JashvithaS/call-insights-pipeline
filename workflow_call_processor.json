          "parameters": []
        },
        "options": {},
        "nodeCredentialType": "supabaseApi"
      },
      "id": "fetch-rules",
      "name": "Fetch active AI rules",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1860,
        380
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o\",\n  \"temperature\": 0.1,\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"You are an expert Admissions Call QA Analyst for ICAG College, Hyderabad. Analyze the provided call transcript and extract structured information. Respond ONLY with valid JSON matching the exact schema provided. No markdown, no extra text.\\n\\nACTIVE RULES \u2014 apply these during analysis:\\n{{ $json.rules_text }}\\n\\nSCORING GUIDE (0-100):\\n90-100: Exceptional \u2014 student highly interested, confirmed walk-in, all details captured\\n70-89: Good \u2014 student interested, positive engagement, clear follow-up\\n50-69: Average \u2014 some interest shown, counselor covered basics\\n30-49: Below average \u2014 minimal engagement, poor counselor performance\\n0-29: Poor \u2014 no interest, missed opportunity, very poor quality\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": \"Call Metadata:\\nSF Number: {{ $('Split into individual calls').item.json.sf_number }}\\nLead Name: {{ $('Split into individual calls').item.json.lead_name }}\\nTeam: {{ $('Split into individual calls').item.json.team_name }}\\nCall Type: {{ $('Split into individual calls').item.json.call_type }}\\n\\nTranscript:\\n{{ $('Transcribe with Whisper').item.json.text }}\\n\\nExtract and return ONLY this JSON schema \u2014 fill every field, use null if not found:\\n{\\n  \\\"program\\\": \\\"string or null\\\",\\n  \\\"course\\\": \\\"string or null\\\",\\n  \\\"phone_number\\\": \\\"string or null\\\",\\n  \\\"college_interested\\\": \\\"boolean\\\",\\n  \\\"walkin_interested\\\": \\\"boolean\\\",\\n  \\\"walkin_date\\\": \\\"YYYY-MM-DD or null\\\",\\n  \\\"follow_up_required\\\": \\\"boolean\\\",\\n  \\\"call_status\\\": \\\"Answered|Missed|Busy|Not Connected|Unknown\\\",\\n  \\\"sentiment\\\": \\\"Positive|Neutral|Negative\\\",\\n  \\\"quality_category\\\": \\\"High Quality|Average|Poor|Very Poor\\\",\\n  \\\"score\\\": \\\"integer 0-100\\\",\\n  \\\"confidence_score\\\": \\\"float 0-1\\\",\\n  \\\"interest_level\\\": \\\"High|Medium|Low|None\\\",\\n  \\\"lead_qualified\\\": \\\"boolean\\\",\\n  \\\"summary\\\": \\\"2-3 sentence summary of the call\\\",\\n  \\\"action_items\\\": [\\\"list of specific next actions\\\"],\\n  \\\"discussion_points\\\": [\\\"key topics discussed\\\"],\\n  \\\"objections\\\": [\\\"concerns or objections raised by student\\\"]\\n}\"\n    }\n  ]\n}",
        "options": {},
        "nodeCredentialType": "openAiApi"
      },
      "id": "gpt-analyze",
      "name": "GPT-4o \u2014 Analyze call",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        2060,
        380
      ]
    },
    {
      "parameters": {
        "jsCode": "// Parse GPT response and prepare Supabase update payload\nconst gptResponse = $input.item.json;\nconst callData = $('split-calls').item.json;\nconst transcript = $('whisper-transcribe').item.json;\n\nlet analysis = {};\ntry {\n  const content = gptResponse.choices[0].message.content;\n  analysis = JSON.parse(content);\n} catch(e) {\n  analysis = { error: e.message };\n}\n\nreturn {\n  json: {\n    // identifiers\n    call_id: callData.id,\n    sf_number: callData.sf_number,\n    // transcript\n    transcript: transcript.text || '',\n    // AI extracted fields\n    program: analysis.program || null,\n    course: analysis.course || null,\n    phone_number: analysis.phone_number || null,\n    college_interested: analysis.college_interested || false,\n    walkin_interested: analysis.walkin_interested || false,\n    walkin_date: analysis.walkin_date || null,\n    follow_up_required: analysis.follow_up_required || false,\n    call_status: analysis.call_status || 'Unknown',\n    sentiment: analysis.sentiment || 'Neutral',\n    quality_category: analysis.quality_category || 'Average',\n    score: parseInt(analysis.score) || 50,\n    confidence_score: parseFloat(analysis.confidence_score) || 0.5,\n    interest_level: analysis.interest_level || 'Low',\n    lead_qualified: analysis.lead_qualified || false,\n    summary: analysis.summary || '',\n    action_items: analysis.action_items || [],\n    discussion_points: analysis.discussion_points || [],\n    objections: analysis.objections || [],\n    raw_ai_json: analysis,\n    status: 'done',\n    processing_done: new Date().toISOString()\n  }\n};"
      },
      "id": "parse-response",
      "name": "Parse GPT response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2260,
        380
      ]
    },
